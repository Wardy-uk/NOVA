# N.O.V.A DayPilot Configuration
# Copy this file to .env and fill in your values.
# All variables are optional — sensible defaults are used when unset.

# ── Server ──
PORT=3069
NODE_ENV=development          # Set to "production" for deployed server

# ── Data directory ──
# Where daypilot.db, users.json, settings.json, and token caches are stored.
# Defaults to the project root. Set this on a production server to a persistent path.
# DATA_DIR=/var/lib/nova              # Linux
# DATA_DIR=C:\ProgramData\NOVA        # Windows Server

# ── SSO callback (reverse proxy) ──
# Set this when running behind IIS/nginx with a different public URL.
# Used for Entra SSO callback redirect URI. Leave empty if same-origin.
# FRONTEND_URL=https://nova.yourcompany.com

# ── Delivery spreadsheet (local xlsx cache) ──
# Full path to the local copy of the delivery spreadsheet.
# Defaults to ~/Downloads/Delivery sheet Master.xlsx
# DELIVERY_XLSX_PATH=/path/to/Delivery sheet Master.xlsx

# ── OneDrive watcher (Power Automate bridge) ──
# Folder that PA drops JSON files into for task ingestion.
# Defaults to ~/OneDrive - Nurtur Limited/DayPilot
# ONEDRIVE_WATCH_DIR=/path/to/watched/folder

# ── Dynamics 365 ──
# CRM organization URL. Defaults to https://nurtur-prod.crm11.dynamics.com
# D365_ORG_URL=https://your-org.crm.dynamics.com

# ── Jira (personal — syncs assigned issues via MCP) ──
JIRA_URL=https://your-instance.atlassian.net
JIRA_PERSONAL_TOKEN=your_pat_here

# ── Microsoft 365 (Planner, To-Do, Calendar, Email) ──
# 1. Register app at https://portal.azure.com > App registrations
# 2. Grant delegated permissions: Tasks.Read, Calendars.Read, Mail.Read, User.Read
# 3. Set "Allow public client flows" = Yes for device code auth
# MS365_MCP_CLIENT_ID=
# MS365_MCP_TENANT_ID=common

# ── Monday.com ──
# 1. Go to monday.com > Avatar > Developers > My Access Tokens
# 2. Create a Personal API Token
# MONDAY_API_TOKEN=
# Optional: comma-separated board IDs to limit sync (default: all boards)
# MONDAY_BOARD_IDS=123456,789012

# ── Azure DevOps (template push to Git) ──
# Configured via Admin > Integrations in the UI. Settings stored in DB:
#   azdo_enabled=true
#   azdo_org=BYM2020              # AzDO organisation name
#   azdo_project=Core             # AzDO project name
#   azdo_repo=TemplateSetCompiler # Git repository name
#   azdo_pat=your_pat_here        # Personal Access Token (Code read+write scope)
#   azdo_base_branch=main         # Target branch for PRs (default: main)

# ── AI (OpenAI for Ask NOVA / standups) ──
# OPENAI_API_KEY=
